# Server
PORT=4000
NODE_ENV=development

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/gmsa_uds"

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# SMS API (e.g. Hubtel, mNotify, Africa's Talking)
SMS_API_URL=https://api.example.com/sms
SMS_API_KEY=your_sms_api_key

# Frontend URL (for CORS and Paystack callback)
FRONTEND_URL=http://localhost:3000

# Paystack (Ghana) – use SECRET key (sk_test_ or sk_live_), not the public key (pk_)
PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret_key

# Email used for Paystack when donor does not provide one (donation form uses Name only)
DONATION_EMAIL=donations@gmsa-uds.org

# Seed (optional): override default admin and password for `npx prisma db seed`
# ADMIN_EMAIL=admin@gmsa.edu.gh
# ADMIN_USERNAME=admin
# SEED_PASSWORD=Password123!
